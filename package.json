{
  "name": "@chrrxs/robloxstudio-mcp-monorepo",
  "version": "2.19.1",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w packages/core && npm run build -w packages/robloxstudio-mcp && npm run build -w packages/robloxstudio-mcp-inspector",
    "compile:plugin": "npm --prefix studio-plugin run build",
    "build:plugin": "npm run compile:plugin && node scripts/build-plugin.mjs",
    "build:plugin:inspector": "npm run compile:plugin && node scripts/build-plugin.mjs --variant inspector",
    "build:plugins": "npm run compile:plugin && node scripts/build-plugin.mjs && node scripts/build-plugin.mjs --variant inspector",
    "build:all": "npm run build && npm run build:plugins",
    "clean": "npm exec --workspaces -- npx rimraf dist",
    "dev": "npm run build -w packages/core && tsx packages/robloxstudio-mcp/src/index.ts",
    "dev:inspector": "npm run build -w packages/core && tsx packages/robloxstudio-mcp-inspector/src/index.ts",
    "start": "node packages/robloxstudio-mcp/dist/index.js",
    "start:inspector": "node packages/robloxstudio-mcp-inspector/dist/index.js",
    "lint": "eslint packages/*/src/**/*.ts",
    "typecheck": "tsc --noEmit -p packages/core/tsconfig.json",
    "test": "npm test -w packages/core",
    "test:e2e:auto-install": "node tests/auto-install-plugin-e2e.mjs",
    "test:studio:tools": "node tests/studio-tooling-smoke.mjs",
    "test:watch": "npm run test:watch -w packages/core",
    "test:coverage": "npm run test:coverage -w packages/core",
    "publish:all": "node scripts/publish.mjs"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "tsup": "^8.0.0",
    "tsx": "^4.6.0",
    "typescript": "^5.3.2"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1"
  }
}
