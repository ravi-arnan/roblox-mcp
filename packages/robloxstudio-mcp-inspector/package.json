{
  "name": "@chrrxs/robloxstudio-mcp-inspector",
  "version": "2.10.1",
  "description": "Read-only MCP Server for Roblox Studio (fork of boshyxd/robloxstudio-mcp-inspector with per-peer execute_luau fixes baked in)",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "robloxstudio-mcp-inspector": "dist/index.js"
  },
  "files": [
    "dist/**/*",
    "studio-plugin/**/*"
  ],
  "scripts": {
    "build": "tsup",
    "prepack": "node ../../scripts/prepack.mjs",
    "postpack": "node ../../scripts/postpack.mjs"
  },
  "keywords": [
    "mcp",
    "roblox",
    "studio",
    "ai",
    "model-context-protocol",
    "game-development",
    "inspector",
    "read-only"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/chrrxs/robloxstudio-mcp.git"
  },
  "homepage": "https://github.com/chrrxs/robloxstudio-mcp#readme",
  "bugs": {
    "url": "https://github.com/chrrxs/robloxstudio-mcp/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.6.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "node-fetch": "^3.3.2",
    "uuid": "^9.0.1",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@chrrxs/robloxstudio-mcp-core": "*"
  }
}
